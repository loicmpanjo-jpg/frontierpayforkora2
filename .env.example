PORT=4000

# ═══════════════════════════════════════════════════════════════════════════
# KORA CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

KORA_BASE_URL=https://api.korapay.com/merchant

# Get these from Kora Dashboard
KORA_PUBLIC_KEY=your_kora_public_key_here
KORA_SECRET_KEY=your_kora_secret_key_here
KORA_ENCRYPTION_KEY=your_kora_encryption_key_here

# Webhook secret for HMAC verification
KORA_WEBHOOK_SECRET=your_kora_webhook_secret_here

# ═══════════════════════════════════════════════════════════════════════════
# VISA CONFIGURATION
# ══════════════════════════════════════════════════��════════════════════════

VISA_BASE_URL=https://sandbox.api.visa.com

# Get these from Visa Developer Portal
VISA_KEY_ID=your_visa_key_id_here
VISA_API_KEY=your_visa_api_key_here
VISA_TLS_USER=your_visa_tls_user_here

# Paths to mTLS certificates (relative to project root)
VISA_CERT_PATH=./certs/cert.pem
VISA_KEY_PATH=./certs/private.key
VISA_CA_PATH=./certs/DigiCertGlobalRootG2.crt.pem

# Webhook secret for HMAC verification
VISA_WEBHOOK_SECRET=your_visa_webhook_secret_here

# Merchant details
VISA_MERCHANT_ID=FRONTIERPAYME
VISA_SENDER_ACCOUNT=4111111111111111

# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=development
